{
  "name": "formant-tracer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:worklet": "npx esbuild app/processors/formant-processor.js --bundle --outfile=public/processors/formant-processor.js --format=esm --external:fs --external:path --external:crypto --banner:js=\"var global = globalThis;\" --inject:./esbuild-shims.js",
    "watch:worklet": "npx esbuild app/processors/formant-processor.js --bundle --outfile=public/processors/formant-processor.js --format=esm --external:fs --external:path --external:crypto --banner:js=\"var global = globalThis;\" --inject:./esbuild-shims.js --watch",
    "dev": "concurrently \"npm run watch:worklet\" \"next dev\"",
    "build": "npm run build:worklet && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@echogarden/pffft-wasm": "^0.4.2",
    "buffer": "^6.0.3",
    "eigen": "^0.2.2",
    "mathjs": "^15.1.1",
    "next": "16.1.6",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
